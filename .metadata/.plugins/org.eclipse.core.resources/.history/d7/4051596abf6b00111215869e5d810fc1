package Day3Task;

public class Task2_Pattern_task {
	public static void main(String[] args) {
		int n = 5;

		for (int i = 1; i <= n; i++) {

			for (int j = n - 1; j >= i; i--) {
				System.out.print("_");
			}
			for (int k = 1; k <= i; k++) {
				if (k == 1 && k == i) {
					System.out.print("1 ");
				} else {
					System.out.print(k);
				}
			}
			System.out.println();
		}
	}

}
