package Day1Task;

public class Task5_ButterFly_pattern {
	public static void main(String[] args) {
		int n=5;
		for(int i=1;i<=n;i++)
		{
			for(int j=1;j<=i;j++)
			{System.out.print("*");
				
			}
			for(int k=n;k>=1;k--)
			{
				System.out.print(" ");
			}
			for(int j=1;j<=i;j++)
			{
				System.out.print("*");
				
			}
		}
	}

}
