package Day1Task;

public class Task3_Hallow_Sqauare {
	public static void main(String[] args) {
		int n = 5;
		for (int i = 1; i <= n; i++)
		{
			System.out.print("*");
		}
		System.out.println();
		for (int i = 1; i < n-1; i++) {
			for (int j = 1; j <= n; j++) {
				if (j == 1 || j == 5) {
					System.out.print("*");
				} else {
					System.out.print(" ");
				}
			}
			System.out.println();
		}

	}

}
