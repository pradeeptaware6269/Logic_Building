package Day1Task;

import java.util.Scanner;

// Task no 1 convert the decimal number to the binary number 
public class Task1_Decimal_to_Binary {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("Here we are converting the Decimal To Binary Number ");
		System.out.println("Enter the value of  Number :");
		int num = sc.nextInt();
		
		
		
		while(num>0)
		{
			int digit=num%2;    // for the remender
			System.out.println(digit);
			num=num/2;    // for the coefficeint
		}

	}

}
