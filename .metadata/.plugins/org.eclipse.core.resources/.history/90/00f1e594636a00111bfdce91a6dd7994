package Day2Task;

import java.util.Scanner;

public class Task4_Decimal_to_Octal {
	public static void main(String[] args) {

		int num, digit = 0, temp = 0, temp1 = 0;
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Decimal Number :");
		num = sc.nextInt();

		System.out.println("here we are converting the Decimal Number to the Octal Number");
		System.out.println("Decimal Number is :" + num);
		while (num > 0) {
			digit = num % 8;
			temp = temp * 10 + digit;
			num = num / 8;
		}
		while (temp > 0) {
			digit = temp % 10;
			temp1 = temp1 * 10 + digit;
			temp = temp / 10;
		}

		System.out.println("The Octal Number is :" + temp1);
	}

}
