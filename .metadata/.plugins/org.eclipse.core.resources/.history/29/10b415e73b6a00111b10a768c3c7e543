package Day2Task;

import java.util.Scanner;

public class Task4_Decimal_to_Octal {
	public static void main(String[] args) {

		int num, digit = 0;
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Decimal Number :");
		num = sc.nextInt();

		while (num > 0) {
			digit = num % 8;
			System.out.print(digit);
		}
	}

}
