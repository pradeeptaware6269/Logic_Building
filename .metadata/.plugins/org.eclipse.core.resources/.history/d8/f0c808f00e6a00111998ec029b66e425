package Day2Task;

import java.util.Scanner;

// For the Duck Number 
public class Task3_Duck_Number {
	public static void main(String[] args) {
		int num, digit = 0, count = 0;
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Number ");
		num = sc.nextInt();
		while (num > 0) {
			digit = num % 10;
			if (digit == 0) {
				count++;
			}

			num = num / 10;
		}

		if (count > 1) {
			System.out.println("Given  Number  Duck Number :");
		} else {
			System.out.println("Given Number not Duck Number :");
		}
	}

}
