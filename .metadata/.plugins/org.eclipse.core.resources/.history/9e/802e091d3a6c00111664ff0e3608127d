package Day4Task;

import java.util.Scanner;

public class Task2_Sort_Array {
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		System.out.println("Enter the Toatl No of Array Element :");
		int n = sc.nextInt();
		int arr[] = new int[n];

		System.out.println("Enter the Array Element :");
		for (int i = 0; i < arr.length; i++) {
			arr[i] = sc.nextInt();
		}

		System.out.println("Here we are trying to sorting the Array :");
		for (int i = 0; i < arr.length; i++) {
			for (int j = 0; j < arr.length; j++) {
				if (arr[i] == arr[j]) {
					continue;
				} else {

					int temp = arr[j];
					arr[j] = arr[j + 1];
					arr[j + 1] = temp;
				}
			}
		}
		System.out.println("Here we can print the actual Array :");
		System.out.print(" | ");
		for (int i = 0; i < arr.length; i++) {
			System.out.print(arr[i]);
		}
		System.out.print(" | ");
	}

}
